<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách User</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">Quản Lý User</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="/get-crud">Danh sách</a></li>
                    <li class="nav-item"><a class="nav-link" href="/crud">Thêm mới</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark">Danh Sách Người Dùng</h2>
            <a href="/crud" class="btn btn-primary px-4">+ Thêm User</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0 text-center align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>STT</th>
                                <th>Email</th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Address</th>
                                <th>Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (datalist && datalist.length > 0) { %>
                                <% for(let i = 0; i < datalist.length; i++) { %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td class="text-start"><%= datalist[i].email %></td>
                                    <td><%= datalist[i].firstName %></td>
                                    <td><%= datalist[i].lastName %></td>
                                    <td class="text-start"><%= datalist[i].address %></td>
                                    <td>
                                        <a href="/edit-crud?id=<%= datalist[i]._id %>" class="btn btn-sm btn-warning fw-bold px-3">Sửa</a>
                                        <!-- Thêm hàm xác nhận xóa để tránh click nhầm -->
                                        <a href="/delete-crud?id=<%= datalist[i]._id %>" class="btn btn-sm btn-danger fw-bold px-3" onclick="return confirm('Bạn có chắc chắn muốn xóa user này không?');">Xóa</a>
                                    </td>
                                </tr>
                                <% } %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="py-4 text-muted">Chưa có người dùng nào trong cơ sở dữ liệu.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>