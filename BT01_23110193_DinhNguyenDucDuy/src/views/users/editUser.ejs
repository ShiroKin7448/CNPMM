<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Thông Tin User</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="/">Quản Lý User</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/get-crud">Danh sách</a></li>
                    <li class="nav-item"><a class="nav-link" href="/crud">Thêm mới</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow border-0">
                    <div class="card-header bg-warning text-dark py-3">
                        <h4 class="mb-0 fw-bold">Cập Nhật Thông Tin</h4>
                    </div>
                    <div class="card-body p-4">
                        <form action="/put-crud" method="post">
                            <!-- Ẩn ID gửi lên server -->
                            <input type="hidden" name="id" value="<%= data._id %>">

                            <div class="mb-3">
                                <label class="form-label text-muted">Đang cập nhật cho tài khoản email:</label>
                                <input type="email" class="form-control bg-light" value="<%= data.email %>" disabled>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">First Name</label>
                                    <input type="text" class="form-control" name="firstName" value="<%= data.firstName %>">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Last Name</label>
                                    <input type="text" class="form-control" name="lastName" value="<%= data.lastName %>">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Địa chỉ</label>
                                <input type="text" class="form-control" name="address" value="<%= data.address %>">
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="/get-crud" class="btn btn-outline-secondary px-4">Hủy & Quay lại</a>
                                <button type="submit" class="btn btn-warning fw-bold px-5 text-dark">Lưu Thay Đổi</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>